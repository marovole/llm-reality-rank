---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeaderboardTable from '../../components/LeaderboardTable.astro';
import ScenarioNav from '../../components/ScenarioNav.astro';
import SnapshotNotice from '../../components/SnapshotNotice.astro';
import { pageTitle, scenarioLabel, scenarios, scoresForScenario } from '../../lib/data';

export function getStaticPaths() {
  return scenarios.map((scenario) => ({ params: { scenario: scenario.id } }));
}

const scenarioId = Astro.params.scenario ?? '';
const label = scenarioLabel(scenarioId);
const scenarioScores = scoresForScenario(scenarioId);
---
<BaseLayout title={pageTitle(`${label}场景榜`)} description={`LLM Reality Rank ${label} 场景静态排行榜，展示 reviewed alpha 数据、置信度和缺失维度。`} canonicalPath={`/leaderboard/${scenarioId}/`}>
  <p class="eyebrow">Scenario leaderboard</p>
  <h1>{label}场景榜</h1>
  <p>场景页为静态预渲染路线，刷新和直接访问均返回对应 HTML。若该维度暂无 reviewed alpha 分数，页面会显示明确空状态。</p>
  <ScenarioNav />
  <SnapshotNotice />
  <LeaderboardTable scores={scenarioScores} scenarioId={scenarioId} title={`${label} reviewed alpha 排行`} />
</BaseLayout>
